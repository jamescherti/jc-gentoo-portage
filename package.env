dev-lang/spidermonkey notmpfs.conf
dev-lang/ghc notmpfs.conf
dev-java/openjdk notmpfs.conf

# ----------------------------------------------------------------------------
# Link-Time Optimization (LTO) Assignments
# ----------------------------------------------------------------------------

# Media, Graphics, & Compression
# These packages see the most significant speedups in encoding/decoding and
# rendering throughput.
# media-video/ffmpeg      flto.conf
# media-libs/x264         flto.conf
# media-libs/x265         flto.conf
# media-libs/dav1d        flto.conf
# media-libs/libvpx       flto.conf
# media-libs/libaom       flto.conf
# media-libs/flac         flto.conf
# media-libs/opus         flto.conf
# media-libs/libvorbis    flto.conf
# media-libs/mesa         flto.conf
# media-gfx/imagemagick   flto.conf
# media-libs/libjpeg-turbo flto.conf
# media-libs/libpng       flto.conf
# media-libs/libwebp      flto.conf
# app-arch/zstd           flto.conf
# app-arch/lz4            flto.conf
# app-arch/xz-utils       flto.conf
# app-arch/bzip2          flto.conf
# sys-libs/zlib           flto.conf

# Interpreters, Compilers & Math
# These speed up the execution of other scripts/programs. WARNING: Compiling
# GCC, LLVM, and Clang with LTO will take a massive amount of time and RAM
# (potentially 16GB+ per job).
# dev-lang/luajit         flto.conf
# dev-lang/lua            flto.conf
# dev-lang/spidermonkey   flto.conf
# sys-devel/gcc           flto.conf
# llvm-core/llvm          flto.conf
# llvm-core/clang         flto.conf
# sci-libs/openblas       flto.conf
# sci-libs/fftw           flto.conf
# sci-libs/gsl            flto.conf
# sci-libs/lapack         flto.conf
# dev-db/sqlite           flto.conf
# dev-db/lmdb             flto.conf
dev-libs/tree-sitter    flto.conf

# Cryptography & Core System Libraries
# Minor but frequent system-wide responsiveness gains.
# dev-libs/openssl        flto.conf
# dev-libs/libsodium      flto.conf
# dev-libs/libgcrypt      flto.conf
# dev-libs/glib           flto.conf
# dev-libs/expat          flto.conf
# sys-libs/ncurses        flto.conf
# sys-libs/readline       flto.conf

# ----------------------------------------------------------------------------
# Optimize with -O3
# ----------------------------------------------------------------------------

# # Compression Algorithms
# # These tools rely entirely on tight loop execution and integer math routines
# # executed directly within C/C++ loops. Compiling with -O3 provides maximum
# # throughput gains.
# app-arch/zstd optimize.conf
# app-arch/lz4 optimize.conf
# app-arch/p7zip optimize.conf
# app-arch/lzip optimize.conf
# app-arch/brotli optimize.conf

# # Mathematics, Matrix Calculations, and Scientific Computing
# # These packages implement linear algebra, multi-dimensional array operations,
# # and Fourier transforms. They are designed to exploit heavy loop unrolling
# # and aggressive SIMD vectorization routines.
# sci-libs/openblas optimize.conf
# sci-libs/lapack optimize.conf
# sci-libs/fftw optimize.conf
# sci-libs/gsl optimize.conf
# dev-python/pandas optimize.conf

# # Image and Audio DSP (Digital Signal Processing)
# # These libraries handle continuous pixel operations and audio transformations
# # directly via the compiler's optimization routines. Compiling with -O3
# # reduces latency in live digital filters and neural network evaluations.
# media-libs/gegl optimize.conf
# media-libs/babl optimize.conf
# media-libs/rnnoise optimize.conf
# media-libs/zita-convolver optimize.conf
# media-libs/lsp-plugins optimize.conf
# media-plugins/calf optimize.conf
