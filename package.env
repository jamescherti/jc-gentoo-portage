# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
# Upstream GLib updated the internal g_utf8_next_char macro to strip out an
# implicit (char *) cast to make the type definition more mathematically and
# strictly compliant. However, sdcv-0.5.5 is older code that passes a const
# string into the macro and then attempts to assign the result directly to a
# mutable gchar *nextchar, causing GCC to hit a hard type-conversion block.
#
# Since we are using this as a command-line utility and just want to bypass
# the strict compiler check to let it install, we can safely instruct GCC to
# treat this specific type mismatch as a warning rather than a fatal error by
# using the -fpermissive flag.
app-text/sdcv permissive.conf

# TODO replace it with: emerge --ask net-proxy/proxychains-ng
# The compilation failure occurs because tsocks is an ancient piece of software
# (dating back to the early 2000s) being compiled with a modern version of the
# GCC compiler.
net-proxy/tsocks legacy-c.conf

# ----------------------------------------------------------------------------
# NO TMPFS (Big packages)
# ----------------------------------------------------------------------------
app-office/libreoffice notmpfs.conf
www-client/chromium notmpfs.conf
www-client/firefox notmpfs.conf
dev-qt/qtwebengine notmpfs.conf
mail-client/thunderbird notmpfs.conf
dev-lang/rust notmpfs.conf
sys-devel/gcc notmpfs.conf
sys-devel/llvm notmpfs.conf
sys-devel/clang notmpfs.conf
dev-lang/spidermonkey notmpfs.conf
dev-lang/ghc notmpfs.conf
dev-java/openjdk notmpfs.conf

# ----------------------------------------------------------------------------
# Link-Time Optimization (LTO) Assignments
# ----------------------------------------------------------------------------

# Media, Graphics, & Compression
# These packages see the most significant speedups in encoding/decoding and
# rendering throughput.
#
# These are good lto candidates. Lots of internal abstraction layers, function
# dispatch patterns benefit from inlining, and compression codecs often have
# small hot functions spread across files.
media-video/ffmpeg       lto.conf
media-libs/x264          lto.conf
media-libs/x265          lto.conf
media-libs/dav1d         lto.conf
media-libs/libvpx        lto.conf
media-libs/libaom        lto.conf
media-libs/flac          lto.conf
media-libs/opus          lto.conf
media-libs/opusfile      lto.conf
media-libs/libvorbis     lto.conf
media-libs/libogg        lto.conf
media-gfx/imagemagick    lto.conf
media-libs/libjpeg-turbo lto.conf
media-libs/libpng        lto.conf
media-libs/libwebp       lto.conf
app-arch/zstd            lto.conf
app-arch/lz4             lto.conf
media-libs/soxr          lto.conf

# TODO
# Use flag "pgo"
app-arch/xz-utils        lto.conf
app-shells/bash          lto.conf
sys-devel/binutils       lto.conf

app-editors/emacs        lto.conf
app-editors/emacs        semantic-interposition.conf

app-editors/vim          lto.conf

# Python acts as the backbone for Portage and numerous system utilities.
# Compiling the interpreter with LTO drastically reduces C function overhead in
# the main evaluation loop, yielding a 10% to 20% speedup in script execution
# times.
dev-lang/python          lto.conf
dev-lang/python          semantic-interposition.conf

# Interpreters, parsers, Compilers & Math
# These speed up the execution of other scripts/programs. WARNING: Compiling
# GCC, LLVM, and Clang with LTO will take a massive amount of time and RAM
# (potentially 16GB+ per job).
dev-lang/luajit         lto.conf
dev-lang/lua            lto.conf
dev-lang/spidermonkey   lto.conf
dev-libs/tree-sitter    lto.conf
# TODO
# sys-devel/gcc           lto.conf  # Very high cost, good benefit
# llvm-core/llvm          lto.conf  # Very high cost, good benefit
# llvm-core/clang         lto.conf  # Very high cost, good benefit

# Real-Time Audio & Media Pipelines
# Pipewire manages low-latency audio and video routing. LTO reduces function
# call overhead within its tight, real-time graph processing loops. GStreamer
# acts as the media backbone for GNOME, benefiting similarly during pipeline dispatch.
media-video/pipewire     lto.conf
media-video/wireplumber  lto.conf
media-libs/gstreamer     lto.conf

# Display Server Protocols & Loaders
# These form the bedrock of the display and rendering stack. LTO helps inline
# the dynamic dispatch and trampoline functions essential for low-latency input
# and frame delivery to the compositor.
dev-libs/wayland         lto.conf
x11-base/xwayland        lto.conf
media-libs/vulkan-loader lto.conf

# TODO
# Heavy Desktop Applications
# These are massive C/C++ codebases. LTO provides substantial reductions in
# final binary size and noticeable improvements in startup times and heavy processing
# tasks. WARNING: Compiling LibreOffice with LTO requires massive amounts of
# RAM and time, comparable to compiling GCC or LLVM.
# app-office/libreoffice   lto.conf
media-gfx/gimp           lto.conf

# Modern Image Codecs
# Similar to video codecs, modern image compression involves highly complex algorithms
# spread across dozens of source files. LTO enables tight vectorization and inlining.
media-libs/libjxl        lto.conf
media-libs/libavif       lto.conf
media-libs/openjpeg      lto.conf

# Desktop Compositing & UI (GNOME Core)
# Mutter is the compositor responsible for rendering every frame on the screen.
# LTO inlines the matrix and vector operations required for window transformations,
# reducing 1% low frame times and CPU bottlenecking during UI animations. GTK and
# GNOME Shell see similar event-loop benefits to glib.
x11-wm/mutter            lto.conf
gnome-base/gnome-shell   lto.conf
gui-libs/gtk             lto.conf
x11-libs/gtk+            lto.conf

# Text Shaping & 2D Rendering
# Glyph shaping and 2D canvas drawing are mathematically intense operations that
# occur thousands of times per second when scrolling text or rendering web pages.
# LTO optimizes the heavy cross-file function calls in these foundational libraries.
media-libs/harfbuzz      lto.conf
media-libs/freetype      lto.conf
x11-libs/cairo           lto.conf
x11-libs/pango           lto.conf

# If the machine has a GUI, Mesa is translating OpenGL/Vulkan calls to the GPU.
# LTO helps optimize the heavy CPU overhead involved in driver draw-call
# dispatch and shader compilation. It won't double frame rate, but it can
# significantly reduce CPU bottlenecking and improve low frame times in games
# or heavy desktop compositing.
#
# NOTE: While LTO can reduce CPU overhead in draw-call dispatch, Mesa is
# notoriously sensitive to compiler optimization passes. Depending on your GCC
# and LLVM versions, forcing LTO on Mesa can introduce subtle rendering
# artifacts, segmentation faults in OpenGL applications, or flat-out build
# failures. Leave it enabled for now, but if you experience graphical
# instability, remove LTO from Mesa first.
media-libs/mesa         lto.conf

# SQLite is used by everything from web browsers (Firefox/Chrome) to package
# managers, desktop environment. LTO heavily optimizes its internal bytecode
# engine (the VDBE), making database queries faster across the whole OS.
dev-db/sqlite           lto.conf

# If a GTK-based desktop environment (GNOME, XFCE) or GTK applications are in
# use, glib acts as the core event loop. LTO helps inline its extensive
# type-checking and object-system abstractions, resulting in improved UI
# responsiveness.
dev-libs/glib           lto.conf

# Only uncomment if the system runs software reliant on these libraries (e.g.,
# NumPy, Octave, Blender, scientific simulations). If the system does not
# perform data science or heavy audio/video processing, leave these commented.
sci-libs/fftw           lto.conf  # medium LTO value
sci-libs/gsl            lto.conf  # medium LTO value
sci-libs/lapack         lto.conf  # medium LTO value
sci-libs/openblas       lto.conf  # medium LTO value
dev-db/lmdb             lto.conf  # medium LTO value

# Cryptography & Core System Libraries
# Minor but frequent system-wide responsiveness gains.

# Cryptography (openssl, libsodium, libgcrypt): Similar to zlib, core crypto
# routines are usually hand-written assembly to ensure constant-time execution
# and prevent side-channel attacks. LTO rarely improves them and can sometimes
# interfere with those security guarantees.
# dev-libs/openssl        lto.conf  # Moderate candidates
# dev-libs/libsodium      lto.conf  # Moderate candidates
# dev-libs/libgcrypt      lto.conf  # Moderate candidates

# dev-libs/expat          lto.conf  # Moderate candidates

# sys-libs/ncurses & sys-libs/readline: These handle terminal text UI. They are
# fundamentally bottlenecked by terminal I/O, not CPU speed. LTO here is a waste
# of compile time.
sys-libs/ncurses        lto.conf
sys-libs/readline       lto.conf

# The internal mixdown algorithms and effect renders may execute slightly faster
# before handing the buffer data off to soxr or ffmpeg.
media-sound/audacity    lto.conf

# zlib and bzip2 is already heavily optimized with hand-written assembly
# routines. The compiler's LTO pass cannot optimize hand-written assembly, so
# the benefit is near zero.
# app-arch/bzip2          lto.conf  # low LTO value
# sys-libs/zlib           lto.conf  # low LTO value

# www-client/firefox lto.conf

# ----------------------------------------------------------------------------
# Optimize with -O3
#
# NOTE: Define this before all others
# ----------------------------------------------------------------------------

# TODO: These packages are primarily math engines. They process arrays of data
# (audio samples, video frames) in tight loops. Loop unrolling and vectorization
# at -O3 allow the CPU to process multiple data points per clock cycle.
# media-video/ffmpeg
# media-libs/soxr
# media-libs/x264
# media-libs/x265
# media-libs/dav1d
# media-libs/libvpx
# media-libs/flac
# media-libs/opus
# media-libs/opusfile
# sci-libs/fftw (If you decide to compile it)
# sci-libs/openblas (If you decide to compile it)

# # Compression Algorithms
# # These tools rely entirely on tight loop execution and integer math routines
# # executed directly within C/C++ loops. Compiling with -O3 provides maximum
# # throughput gains.
# app-arch/zstd O3.conf
# app-arch/lz4 O3.conf
# app-arch/p7zip O3.conf
# app-arch/lzip O3.conf
# app-arch/brotli O3.conf

# # Mathematics, Matrix Calculations, and Scientific Computing
# # These packages implement linear algebra, multi-dimensional array operations,
# # and Fourier transforms. They are designed to exploit heavy loop unrolling
# # and aggressive SIMD vectorization routines.
# sci-libs/openblas O3.conf
# sci-libs/lapack O3.conf
# sci-libs/fftw O3.conf
# sci-libs/gsl O3.conf
# dev-python/pandas O3.conf

# # Image and Audio DSP (Digital Signal Processing)
# # These libraries handle continuous pixel operations and audio transformations
# # directly via the compiler's optimization routines. Compiling with -O3
# # reduces latency in live digital filters and neural network evaluations.
# media-libs/gegl O3.conf
# media-libs/babl O3.conf
# media-libs/rnnoise O3.conf
# media-libs/zita-convolver O3.conf
# media-libs/lsp-plugins O3.conf
# media-plugins/calf O3.conf
