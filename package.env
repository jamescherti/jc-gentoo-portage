# TODO: Packages to remove: gnome-base/nautilus, app-misc/tinysparql,
# app-misc/localsearch Technical reason: These are either event-driven GUI
# shells or background I/O daemons. Aggressive loop unrolling and inlining from
# -O3 increases binary size and causes instruction cache (icache) misses without
# speeding up disk I/O or event handling. Recommendation: Keep them in lto.conf
# (where LTO flattens GObject function dispatch overhead), but remove them from
# O3.conf.

# ----------------------------------------------------------------------------
# NO TMPFS (Big packages)
# ----------------------------------------------------------------------------
app-office/libreoffice notmpfs.conf
www-client/chromium notmpfs.conf
www-client/firefox notmpfs.conf
dev-qt/qtwebengine notmpfs.conf
mail-client/thunderbird notmpfs.conf
dev-lang/rust notmpfs.conf
sys-devel/gcc notmpfs.conf
sys-devel/llvm notmpfs.conf
sys-devel/clang notmpfs.conf
dev-lang/spidermonkey notmpfs.conf
dev-lang/ghc notmpfs.conf
dev-java/openjdk notmpfs.conf

# ----------------------------------------------------------------------------
# Optimize with -O3 and lto
# ----------------------------------------------------------------------------
# The internal state machine that parses incoming ANSI escapes could benefit
# from aggressive optimization, making tmux slightly faster at processing the
# data Emacs sends.
app-misc/tmux O3.conf
app-misc/tmux lto.conf

# Mathematics, Matrix Calculations, and Scientific Computing
# These packages implement linear algebra, multi-dimensional array operations,
# and Fourier transforms. They are designed to exploit heavy loop unrolling
# and aggressive SIMD vectorization routines.
sci-libs/fftw O3.conf
sci-libs/fftw           lto.conf  # medium LTO value

sci-libs/openblas O3.conf
sci-libs/openblas       lto.conf  # medium LTO value

sci-libs/lapack O3.conf
sci-libs/lapack         lto.conf  # medium LTO value

sci-libs/gsl O3.conf
sci-libs/gsl            lto.conf  # medium LTO value

# Pipewire acts as a low-latency multimedia routing graph, while Easyeffects
# applies real-time audio filters (like equalizers, compressors, and limiters)
# to those audio streams. Applying audio effects requires executing complex
# mathematical algorithms, such as Fast Fourier Transforms (FFT), over thousands
# of audio samples per second. These are pure matrix operations. The -O3 flag
# enables aggressive auto-vectorization, allowing the CPU to use SIMD
# instructions to process multiple audio frames simultaneously, reducing audio
# latency and CPU load.
media-video/pipewire O3.conf
media-video/pipewire lto.conf

# Real-Time Audio & Media Pipelines
# Pipewire manages low-latency audio and video routing. LTO reduces function
# call overhead within its tight, real-time graph processing loops. GStreamer
# acts as the media backbone for GNOME, benefiting similarly during pipeline dispatch.
media-video/pipewire     lto.conf

# Gimp is CPU-bound. GIMP iterates over massive arrays of pixels to apply color
# space conversions, blur filters, and scaling algorithms. Ghostscript is an
# interpreter that takes These floating-point calculation loops benefit from the
# function inlining and loop unrolling provided by -O3.
media-gfx/gimp O3.conf

# Heavy Desktop Applications
# These are massive C/C++ codebases. LTO provides substantial reductions in
# final binary size and noticeable improvements in startup times and heavy processing
# tasks. WARNING: Compiling LibreOffice with LTO requires massive amounts of
# RAM and time, comparable to compiling GCC or LLVM.
# app-office/libreoffice   lto.conf
media-gfx/gimp lto.conf

# These are the GNOME desktop indexers. They constantly parse text, extract file
# metadata, and run SQLite queries in the background. Applying -O3 increases
# their text-processing throughput and reduces background CPU load during
# indexing phases.
app-misc/localsearch O3.conf
app-misc/tinysparql O3.conf

# Applying the -O3 optimization level and Link-Time Optimization (LTO) to
# gui-apps/gnome-console improves the execution speed and binary footprint of
# the terminal frontend. Because the application is built on GTK4 and the
# GObject system, it uses small callback functions and signal handlers that
# benefit from the aggressive function inlining provided by -O3. Furthermore,
# LTO analyzes the entire program graph during the linking phase to perform
# cross-module inlining and eliminate unused GObject boilerplate code. This
# combination reduces UI event latency and minimizes the final executable size,
# resulting in faster startup times and more responsive window management
# without compromising the stability of the underlying VTE terminal process.
gui-apps/gnome-console O3.conf
gui-apps/gnome-console lto.conf

x11-terms/gnome-terminal O3.conf
x11-terms/gnome-terminal lto.conf

# This library handles the processing logic for the terminal, including ANSI
# escape sequence parsing, scrollback buffer management, and text drawing.
# Optimizing this package yields the most direct latency reduction for the
# terminal emulator.
gui-libs/vte O3.conf
gui-libs/vte lto.conf

# Applying -O3 and Link-Time Optimization (LTO) to gui-libs/libadwaita improves
# GTK4 UI responsiveness and reduces memory overhead by optimizing widget layout
# calculations and gesture processing. Aggressive inlining from -O3 minimizes
# function call latency within libadwaita's GObject-heavy codebase, while LTO
# performs cross-module inlining and strips out unused type-checking boilerplate
# at link time. This results in smoother animations, faster application startup,
# and a smaller library footprint.
gui-libs/libadwaita O3.conf
gui-libs/libadwaita lto.conf

# These are the GNOME desktop indexers. They constantly parse text, extract file
# metadata, and run SQLite queries in the background. Applying LTO increases
# their text-processing throughput and reduces background CPU load during
# indexing phases.
app-misc/localsearch lto.conf
app-misc/tinysparql lto.conf

# This contains the core digital signal processing (DSP) and mathematical
# routines for GStreamer media pipelines. Both LTO is recommended to match the
# optimizations you already applied to FFmpeg and PipeWire.
media-libs/gst-plugins-base O3.conf

# This contains the core digital signal processing (DSP) and mathematical
# routines for GStreamer media pipelines. Both LTO is recommended to match the
# optimizations you already applied to FFmpeg and PipeWire.
media-libs/gst-plugins-base lto.conf

# Aggressively inline the internal C code to reduce UI dispatch overhead
gnome-base/nautilus O3.conf

# Flatten the object-oriented calls between Nautilus, GTK, and GLib
gnome-base/nautilus lto.conf

# This is purely CPU-bound. Compiling pcre and pcre2 with -O3 allows the
# compiler to use auto-vectorization (SIMD instructions), which can speed up
# complex regex searches in massive scrollback buffers.
dev-libs/libpcre O3.conf
dev-libs/libpcre2 O3.conf

# Regular expression state machines span multiple files. LTO reduces the
# branching overhead between the regex compiler and the execution engine.
dev-libs/libpcre2 lto.conf
dev-libs/libpcre lto.conf

# Calculating precise glyph positioning, kerning pairs, ligatures, and
# rasterizing vector font outlines into bitmaps involves floating-point
# arithmetic. These are CPU-bound rendering tasks where loop unrolling and
# function inlining provide speed improvements.
media-libs/harfbuzz O3.conf
media-libs/freetype O3.conf
x11-libs/cairo O3.conf
x11-libs/pango O3.conf

# Text Shaping & 2D Rendering
# Glyph shaping and 2D canvas drawing are mathematically intense operations that
# occur thousands of times per second when scrolling text or rendering web pages.
# LTO optimizes the heavy cross-file function calls in these foundational libraries.
media-libs/harfbuzz      lto.conf
media-libs/freetype      lto.conf
x11-libs/cairo           lto.conf
x11-libs/pango           lto.conf

# Git stores compressed snapshots and computes binary deltas between blobs to
# save space. When run git gc, git push, or git clone, Git spends most of its
# execution time compressing data via zlib and computing these deltas.
# Compression algorithms rely on tight, repetitive loops for dictionary lookups
# and bitwise operations. The -O3 flag enables auto-vectorization and loop
# unrolling, which directly increases the throughput of these CPU-bound tasks.
dev-vcs/git O3.conf

# LTO allows the compiler to inline the delta compression and packfile traversal
# functions across Git's internal object storage modules.
dev-vcs/git lto.conf

# While mpv offloads video decoding to the GPU when possible, its internal
# rendering pipeline, color management, scaling filters, and subtitle rendering
# (via libass) rely on CPU calculations. Compiling mpv with -O3 ensures the
# software-rendering fallbacks and post-processing pipelines execute as fast as
# possible.
media-video/mpv O3.conf

# The C codebase abstracts rendering, scaling, and subtitle synchronization
# across many distinct modules. LTO removes the function call dispatch penalty
# between them.
media-video/mpv lto.conf

# Both are PDF rendering engines. Converting vector data, drawing paths, and
# rendering embedded fonts into pixel buffers on the CPU requires tight,
# repetitive mathematical loops.
app-text/poppler O3.conf
app-text/mupdf O3.conf

# These rely on heavy C++ abstractions. LTO flattens the object-oriented
# overhead during PDF rendering and path drawing.
app-text/poppler lto.conf
app-text/mupdf lto.conf

# Software rendering and pixel compositing. Pixman is the backend for Cairo.
# Matrix transformations and alpha blending loops benefit directly from SIMD.
x11-libs/pixman O3.conf

# Compositing operations are split into many modular fast-paths. LTO helps the
# compiler inline these pixel manipulation routines directly into the calling
# functions.
x11-libs/pixman lto.conf

# Low-Level Rendering and Text Parsing
dev-libs/libxslt O3.conf
dev-libs/libxml2 O3.conf

# The DOM tree traversal functions jump across multiple internal API boundaries,
# which LTO optimizes away.
dev-libs/libxml2 lto.conf
dev-libs/libxslt lto.conf

# Ghostscript is an interpreter that takes vector instructions (PostScript or
# PDF) and rasterizes them into high-resolution bitmaps for your CUPS printer
# queue. These floating-point calculation loops benefit from the function
# inlining and loop unrolling provided by -O3.
app-text/ghostscript-gpl O3.conf

# PostScript interpretation relies on a massive state machine split across
# dozens of directories.
app-text/ghostscript-gpl lto.conf

# These libraries handle the node-based rendering graph and pixel format
# conversions for software like GIMP. Utilizing -O3 here directly reduces the
# latency you experience when applying filters to large canvases.
media-libs/gegl O3.conf
media-libs/babl O3.conf

# media-libs/libraw: Decodes RAW sensor data from digital cameras. The
# de-mosaicing algorithms (converting Bayer patterns to RGB) process millions of
# pixels sequentially.
media-libs/libraw O3.conf

# The image processing nodes and color space conversions gain throughput when
# the compiler can see across the graph execution units.
media-libs/gegl lto.conf
media-libs/babl lto.conf
media-libs/libraw lto.conf

# Compression and decompression algorithms spend their execution time in tight
# loops performing memory shifts, dictionary lookups, and bitwise operations.
# Modern algorithms (like Zstandard, LZ4, and Brotli) as well as classic
# DEFLATE implementations (zlib, gzip) are highly CPU-bound. These packages
# are ideal candidates for the -O3 flag, which enables aggressive loop
# unrolling, function inlining, and auto-vectorization (SIMD instructions)
# to maximize data throughput and reduce processing time.
sys-libs/zlib O3.conf
sys-libs/zlib lto.conf

app-arch/gzip O3.conf
app-arch/gzip lto.conf

app-arch/zstd O3.conf
app-arch/zstd lto.conf

app-arch/lz4 O3.conf
app-arch/lz4 lto.conf

app-arch/7zip O3.conf
app-arch/7zip lto.conf

app-arch/lzip O3.conf
app-arch/lzip lto.conf

app-arch/brotli O3.conf
app-arch/brotli lto.conf

app-arch/unzip O3.conf
app-arch/unzip lto.conf

app-arch/zip O3.conf
app-arch/zip lto.conf

app-arch/bzip2 O3.conf
app-arch/bzip2 lto.conf

app-arch/xz-utils O3.conf
app-arch/xz-utils lto.conf

# These packages are primarily math engines. They process arrays of data
# (audio samples, video frames) in tight loops. Loop unrolling and vectorization
# at -O3 allow the CPU to process multiple data points per clock cycle.
media-video/ffmpeg O3.conf
media-libs/x264 O3.conf
media-libs/x265 O3.conf
media-libs/dav1d O3.conf
media-libs/libvpx O3.conf
media-libs/libaom O3.conf
media-libs/svt-av1 O3.conf

media-libs/flac O3.conf
media-libs/opus O3.conf
media-libs/opusfile O3.conf
media-libs/libvorbis O3.conf
media-libs/libsamplerate O3.conf
media-libs/libogg O3.conf
media-libs/libsndfile O3.conf
media-libs/soxr O3.conf

media-libs/libjxl O3.conf
media-libs/libavif O3.conf
media-libs/openjpeg O3.conf
media-libs/libwebp O3.conf
media-libs/libjpeg-turbo O3.conf
media-libs/libpng O3.conf
media-libs/giflib O3.conf
media-gfx/imagemagick O3.conf
gnome-base/librsvg O3.conf
media-libs/tiff O3.conf
media-gfx/exiv2 O3.conf
media-libs/lcms O3.conf

# Media, Graphics, & Compression
# These packages see the most significant speedups in encoding/decoding and
# rendering throughput.
#
# These are good lto candidates. Lots of internal abstraction layers, function
# dispatch patterns benefit from inlining, and compression codecs often have
# small hot functions spread across files.
media-video/ffmpeg       lto.conf
media-libs/x264          lto.conf
media-libs/x265          lto.conf
media-libs/dav1d         lto.conf
media-libs/libvpx        lto.conf
media-libs/libaom        lto.conf
media-libs/svt-av1       lto.conf

media-libs/flac          lto.conf
media-libs/opus          lto.conf
media-libs/opusfile      lto.conf
media-libs/libvorbis     lto.conf
media-libs/libsamplerate lto.conf
media-libs/libogg        lto.conf
media-libs/libsndfile    lto.conf
media-libs/soxr          lto.conf

# Modern Image Codecs
# Similar to video codecs, modern image compression involves highly complex algorithms
# spread across dozens of source files. LTO enables tight vectorization and inlining.
media-libs/libjxl lto.conf
media-libs/libavif lto.conf
media-libs/openjpeg lto.conf
media-libs/libwebp lto.conf
media-libs/libjpeg-turbo lto.conf
media-libs/libpng lto.conf
media-libs/giflib lto.conf
media-gfx/imagemagick lto.conf
gnome-base/librsvg lto.conf
media-libs/tiff lto.conf
media-gfx/exiv2 lto.conf
media-libs/lcms lto.conf

# Tree-sitter dynamically builds and updates Abstract Syntax Trees (ASTs) on
# every keystroke. Its parsing engine is a complex state machine that constantly
# traverses memory structures. Compiling this with -O3 optimizes the branching
# logic and inlines the node traversal functions, reducing the overhead of
# real-time syntax highlighting.
dev-libs/tree-sitter O3.conf

# Interpreters, parsers, Compilers & Math
# These speed up the execution of other scripts/programs.
dev-libs/tree-sitter lto.conf

# Moderate Benefit: Parsing, Databases, and Emacs
# These packages involve heavy graph traversal, Abstract Syntax Tree (AST)
# manipulation, and complex memory management.
#
# emacs: The Emacs C core (which handles the Lisp interpreter, display engine,
# and garbage collector) will execute Lisp evaluation and buffer rendering
# faster.
#
# sqlite: Query parsing and B-Tree traversal benefit from aggressive inlining.
#
dev-db/sqlite O3.conf

# SQLite is used by everything from web browsers (Firefox/Chrome) to package
# managers, desktop environment. LTO optimizes its internal bytecode engine (the
# VDBE), making database queries faster across the whole OS.
dev-db/sqlite           lto.conf

# Emacs
app-editors/emacs O3.conf
app-editors/emacs lto.conf
app-editors/emacs semantic-interposition.conf

# Real-Time Audio DSP
#
# For real-time audio, the CPU must compute the output buffer before the sound
# interface hardware demands it. Failing to meet this deadline causes buffer
# underruns (audio dropouts or clicks). Aggressive optimization reduces the CPU
# cycles required to process each block of audio samples.
#
# media-libs/zita-convolver: Convolution algorithms rely entirely on Fast
# Fourier Transforms (FFT). FFT math scales exceptionally well with -O3 due to
# predictable loop structures.
#
# media-libs/lsp-plugins and media-plugins/calf: These plugin suites execute
# algorithms for compression, equalization, and saturation on every single audio
# sample flowing through the digital audio workstation (DAW).
#
# media-libs/rnnoise: Evaluating recurrent neural networks for noise suppression
# involves constant, heavy matrix multiplications that benefit greatly from
# compiler vectorization.
media-libs/rnnoise O3.conf
media-libs/zita-convolver O3.conf
media-libs/lsp-plugins O3.conf
media-plugins/calf O3.conf

# Audio DSP algorithms abstract the filter mathematics from the plugin
# interface. LTO merges them for lower latency per audio frame.
media-libs/rnnoise lto.conf
media-libs/zita-convolver lto.conf
media-libs/lsp-plugins lto.conf
media-plugins/calf lto.conf

# ----------------------------------------------------------------------------
# Optimize with -O3
#
# NOTE: Define this before all others
# ----------------------------------------------------------------------------
# Real-Time Audio & Media Pipelines
media-sound/easyeffects O3.conf

# This handles Unicode normalization, case-folding, and parsing of UTF-8
# strings. Character encoding and string parsing are purely CPU-bound,
# mathematical operations. They rely on tight loops iterating over character
# arrays.
#
# The -O3 flag enables auto-vectorization and aggressive loop unrolling. Tmux
# uses this library to parse and validate the incoming UTF-8 streams. Optimizing
# this library directly speeds up text parsing.
dev-libs/libutf8proc O3.conf

# Arbitrary-precision arithmetic (used by Emacs for large numbers) are strictly
# bounded by CPU cycles. While these libraries often contain hand-written
# assembly for critical paths, -O3 ensures the C-level orchestration code and
# fallback paths run as fast as possible.
dev-libs/gmp O3.conf

# When you use git grep or search through logs with regular expressions, Git
# delegates the work to PCRE2. XML parsing for network protocols (expat), and
# code formatting (highlight) are CPU-bound. The text parsing engines act as
# dense state machines. Aggressive function inlining from -O3 removes function
# call overhead during string scanning, making repository searches noticeably
# faster.
dev-libs/expat O3.conf
# dev-libs/expat lto.conf  # Moderate candidates
app-text/highlight O3.conf

# An optical character recognition engine. The internal neural network inference
# and matrix math benefit heavily from SIMD instructions and loop unrolling.
app-text/tesseract O3.conf

# jq parses JSON strings into abstract syntax trees in memory.
app-misc/jq O3.conf

# This yields performance improvements for vterm users because terminal
# emulation is a purely CPU-bound task. The library spends its execution time
# running a complex state machine to parse dense ANSI escape sequences and
# performing continuous memory shifts to update the terminal grid during scroll
# events.
dev-libs/libvterm O3.conf

# File comparison tools (diff, cmp) rely on difference algorithms and
# byte-by-byte string matching. When comparing large files or deep source trees
# that are already cached in RAM, these tools become entirely CPU-bound. The -O3
# flag provides auto-vectorization and loop unrolling that directly accelerates
# these intensive memory scanning loops.
sys-apps/diffutils O3.conf

# While aide reads your filesystem (which is I/O bound), it calculates complex
# cryptographic hashes (like SHA-256 or SHA-512) for every single file to detect
# tampering. git-crypt performs AES encryption on your repository data.
# Cryptographic hashing and encryption rely on continuous, tight mathematical
# loops that benefit immensely from loop unrolling and vectorization.
app-forensics/aide O3.conf

# Generating a thumbnail for a video requires seeking into a highly compressed
# media file (like H.264, HEVC, or AV1), decoding the mathematical
# transformations of that specific I-frame, and rasterizing it into a bitmap.
# This relies on the underlying FFmpeg libraries. Applying -O3 enables
# SIMD vectorization for the macroblock decoding and pixel format conversion
# loops, making directory loading noticeably faster when opening folders filled
# with large video files.
media-video/ffmpegthumbnailer O3.conf

# While gthumb is an image viewer, it performs heavy on-the-fly image
# processing. When you open a directory of high-resolution RAW photos or JPEGs,
# gthumb decodes them, applies color management profiles, and scales them down
# for the thumbnail grid. Pixel scaling algorithms (like Lanczos or bicubic) are
# matrix multiplications that benefit directly from the aggressive loop
# unrolling provided by -O3.
media-gfx/gthumb O3.conf

# This is a full-text search engine. The indexing daemon parses megabytes of
# text and builds complex, compressed Xapian database indexes in the background.
# -O3 will speed up the string tokenization and indexing loops.
# TODO
app-misc/recoll O3.conf

# Cryptographic and high-speed hashing algorithms. These execute tight bitwise
# loops over memory buffers.
dev-libs/xxhash O3.conf
app-crypt/libb2 O3.conf
app-crypt/argon2 O3.conf
app-crypt/mhash O3.conf
app-crypt/rhash O3.conf

# Low-Level Rendering and Text Parsing
dev-cpp/simdutf O3.conf

# A tool for tracing bitmaps into vector graphics. The polygon fitting and curve
# calculations are completely CPU-bound.
#
# The pathfinding, polygon fitting, and Bezier curve algorithms are purely
# mathematical and highly CPU-bound.
media-gfx/potrace O3.conf

# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
# Upstream GLib updated the internal g_utf8_next_char macro to strip out an
# implicit (char *) cast to make the type definition more mathematically and
# strictly compliant. However, sdcv-0.5.5 is older code that passes a const
# string into the macro and then attempts to assign the result directly to a
# mutable gchar *nextchar, causing GCC to hit a hard type-conversion block.
#
# Since we are using this as a command-line utility and just want to bypass
# the strict compiler check to let it install, we can safely instruct GCC to
# treat this specific type mismatch as a warning rather than a fatal error by
# using the -fpermissive flag.
app-text/sdcv permissive.conf

# TODO replace it with: emerge --ask net-proxy/proxychains-ng
# The compilation failure occurs because tsocks is an ancient piece of software
# (dating back to the early 2000s) being compiled with a modern version of the
# GCC compiler.
net-proxy/tsocks legacy-c.conf

# ----------------------------------------------------------------------------
# jemalloc
# ----------------------------------------------------------------------------

# Compiling software is one of the heaviest workloads on a Gentoo system. Clang
# and the LLD linker generate millions of rapid allocations when parsing C++
# abstract syntax trees and linking binaries. Injecting jemalloc significantly
# reduces peak RAM usage during the link phase and speeds up your total compile
# times.
llvm-core/clang jemalloc.conf
llvm-core/llvm jemalloc.conf

# Squid caches millions of small web objects. Over a long uptime, standard
# allocators fragment heavily, causing the proxy to consume excessive RAM.
# Linking jemalloc keeps Squid's memory usage flat and predictable.
net-proxy/squid jemalloc.conf

# ImageMagick processes massive image files, often creating thousands of
# short-lived allocations when applying filters, resizing, or converting
# formats.
# Benefit: May slightly reduce peak memory usage and marginally speed up batch
# image processing operations.
# Risk: Generally stable, but can slow down certain single-threaded operations
# where glibc's default arenas are already highly optimized.
# media-gfx/imagemagick jemalloc.conf

# ----------------------------------------------------------------------------
# Link-Time Optimization (LTO) Assignments
# ----------------------------------------------------------------------------
# squid can actually benefit from Link-Time Optimization. Unlike git, which is
# largely constrained by local filesystem metadata operations, Squid is a
# massive C++ daemon that performs continuous, heavy text parsing and ruleset
# evaluation.
net-proxy/squid          lto.conf

# Use flag "pgo"
app-shells/bash          lto.conf

# We are avoiding forcing -flto=auto on sys-devel/binutils via environment
# variable injection. Binutils provides the core system linker (ld) and
# assembler (as). Forcing arbitrary CFLAGS onto the toolchain bypassing the
# ebuild logic is unsafe. If a subtle optimization bug corrupts the linker,
# Gentoo will be completely unable to compile new software from source. If you
# want to optimize binutils, use the package manager native USE flags instead.
# sys-devel/binutils       lto.conf

# Python acts as the backbone for Portage and numerous system utilities.
# Compiling the interpreter with LTO drastically reduces C function overhead in
# the main evaluation loop, yielding a 10% to 20% speedup in script execution
# times.
dev-lang/python          lto.conf
dev-lang/python          semantic-interposition.conf

# Editors
app-editors/vim          lto.conf

# Interpreters, parsers, Compilers & Math
# These speed up the execution of other scripts/programs. WARNING: Compiling
# GCC, LLVM, and Clang with LTO will take a massive amount of time and RAM
# (potentially 16GB+ per job).
dev-lang/luajit         lto.conf
dev-lang/lua            lto.conf

# Very high cost, good benefit
# sys-devel/gcc           lto.conf
llvm-core/llvm          lto.conf
llvm-core/clang         lto.conf

# Real-Time Audio & Media Pipelines
# Pipewire manages low-latency audio and video routing. LTO reduces function
# call overhead within its tight, real-time graph processing loops. GStreamer
# acts as the media backbone for GNOME, benefiting similarly during pipeline dispatch.
media-video/wireplumber  lto.conf
media-libs/gstreamer     lto.conf

# Display Server Protocols & Loaders
# These form the bedrock of the display and rendering stack. LTO helps inline
# the dynamic dispatch and trampoline functions essential for low-latency input
# and frame delivery to the compositor.
dev-libs/wayland         lto.conf
x11-base/xwayland        lto.conf
media-libs/vulkan-loader lto.conf

# Desktop Compositing & UI (GNOME Core)
# Mutter is the compositor responsible for rendering every frame on the screen.
# LTO inlines the matrix and vector operations required for window transformations,
# reducing 1% low frame times and CPU bottlenecking during UI animations. GTK and
# GNOME Shell see similar event-loop benefits to glib.
x11-wm/mutter            lto.conf
gnome-base/gnome-shell   lto.conf
gui-libs/gtk             lto.conf
x11-libs/gtk+            lto.conf

# Flatten the GTK 4 and GObject UI abstractions for slightly lower scrolling
# latency. The actual PDF rendering (Poppler/Cairo) is already heavily
# optimized.
app-text/papers lto.conf

# This is the bridge driving GNOME Shell's interface. Optimizing the
# JavaScript-to-C binding layers removes the remaining dispatch overhead between
# user actions and window manager reactions.
dev-libs/gjs lto.conf

# If a GTK-based desktop environment (GNOME, XFCE) or GTK applications are in
# use, glib acts as the core event loop. LTO helps inline its extensive
# type-checking and object-system abstractions, resulting in improved UI
# responsiveness.
dev-libs/glib lto.conf

# Cryptography & Core System Libraries
# Minor but frequent system-wide responsiveness gains.

# The internal mixdown algorithms and effect renders may execute slightly faster
# before handing the buffer data off to soxr or ffmpeg.
media-sound/audacity lto.conf

# If you use NetworkManager's shared connections or a lightweight local DNS/DHCP
# cache, dnsmasq handles thousands of rapid network string parses. LTO provides
# crisp improvements to string lookups in local cache structures.
# net-dns/dnsmasq lto.conf

# Flatten the Vala/GObject abstractions to reduce UI dispatch overhead. The disk
# scanning is entirely I/O bound.
sys-apps/baobab lto.conf

dev-db/lmdb lto.conf  # medium LTO value

# Core cryptographic math in these libraries is implemented in hand-written
# assembly and unaffected by compiler flags. LTO optimizes the surrounding C
# orchestration layers by inlining wrapper functions, flattening API boundaries,
# and streamlining state machines (such as TLS handshakes and packet parsing).
#
# Do not use -O3 here: passing -O3 to the C orchestration code can alter
# branching or memory access patterns, potentially compromising constant-time
# execution guarantees meant to prevent side-channel timing attacks.
net-libs/gnutls lto.conf
dev-vcs/git-crypt lto.conf
app-crypt/gnupg lto.conf
dev-libs/libgcrypt lto.conf
dev-libs/libsodium lto.conf
dev-libs/openssl lto.conf
