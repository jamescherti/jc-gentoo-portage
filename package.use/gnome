# Global configuration
# TODO: Is -gnome-keyring useful?
*/* -qt5 -qt6 -gnome-online-accounts -gnome-keyring wayland -geolocation

# Disable KDE
*/* -kde -kaccounts -semantic-desktop

# GNOME: Prune comic book archive formats from the primary document viewer
app-text/papers -comics

# GNOME: Strip Indexing and Cache Bloat (Minimalist Tuning)
app-misc/localsearch -jpeg -tiff -pdf -playlist -iso -cue -exif

# GNOME: Portage reports a missing configuration dependency for libcanberra
# Because I chose to run a pure PipeWire layout (-pulseaudio globally),
# libcanberra needs to be told to build its standard translation layer so audio
# streams can be passed over to PipeWire's daemon emulation pathways.
# >=media-libs/libcanberra-0.30-r8 pulseaudio

# GNOME: Required by net-fs/samba to support modern encrypted network transport
# states
net-libs/ngtcp2 gnutls

# GNOME: Exclude previewer, cloud, weather, and heavy multi-lingual input
# layers from the desktop stack
gnome-base/nautilus -cloudproviders -previewer
gnome-extra/evolution-data-server -weather
gnome-base/gnome-shell -ibus
gnome-base/gnome-control-center -ibus

# The machine pings an external server every few minutes, leaking your IP
# address and uptime status to whoever hosts that endpoint.  It prevents
# unnecessary background HTTP requests, keeping your system network traffic
# strictly bounded to things you explicitly execute.
net-misc/networkmanager -concheck

# Omit physical sensor calibration layers and flatbed scanning daemons
# gnome-base/gnome-settings-daemon -colord
# gnome-base/gnome-control-center -colord

# GNOME: Remove Active Directory and Samba
net-fs/cifs-utils -ads

# GNOME: Disable screencast
x11-wm/mutter -screencast
