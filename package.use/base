# -evdev: Used both in console and X/Wayland
*/* -wxwidgets -sdl -sdl2 -evdev alsa nvme apparmor bluetooth lvm bash-completion lm-sensors hddtemp verify-sig cryptsetup

# sys-kernel/gentoo-kernel requirement
# The Linux kernel cannot natively decrypt a LUKS container or scan for LVM
# logical volumes on its own. It requires the early user-space environment
# provided by an initramfs, which contains the necessary cryptsetup and lvm
# binaries to unlock and mount your root partition before the main init system
# starts.
sys-kernel/installkernel dracut

# The symlink flag automatically creates or updates a symbolic link at
# /usr/src/linux pointing to your current kernel source code.
sys-kernel/gentoo-sources symlink
sys-kernel/zen-sources symlink

# Disable legacy translation databases for modern IPP printers
net-print/cups-meta -foomatic
net-print/cups-filters -foomatic

# Minimalist Vim
app-editors/vim -X acl -crypt -gpm -sound -wayland

# I am running a minimal GTK-based desktop environment (gnome-light) and use
# tools like GIMP, keeping qt6 enabled on matplotlib will force Portage to pull
# in a massive portion of the Qt6 toolkit framework framework (such as
# dev-qt/qtbase), which you do not need.
dev-python/matplotlib -qt6

# basic, open-source GPU-compute capabilities without cluttering the
# system-wide configurations for gallium.
# Based on the applications in my Ansible playbook and my current hardware
# stack, OpenCL is completely useless
# media-libs/mesa opencl

# Prune massive redundant typography packages from the install plan
# I do not need 14 different font families for a clean desktop layout. GNOME
# natively relies on media-fonts/cantarell for its system shell, and the
# terminal code layouts will look crisp using media-fonts/source-code-pro or
# dejavu.
media-fonts/fonts-meta -latin

