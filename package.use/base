# -evdev: Used both in console and X/Wayland
# ssl: Mandatory for secure web traffic, fetching packages, and encrypted communication.
*/* -wxwidgets -sdl -sdl2 -evdev ssl alsa nvme apparmor bluetooth lvm bash-completion lm-sensors hddtemp verify-sig cryptsetup

# sys-kernel/gentoo-kernel requirement
# The Linux kernel cannot natively decrypt a LUKS container or scan for LVM
# logical volumes on its own. It requires the early user-space environment
# provided by an initramfs, which contains the necessary cryptsetup and lvm
# binaries to unlock and mount your root partition before the main init system
# starts.
sys-kernel/installkernel dracut

# The symlink flag automatically creates or updates a symbolic link at
# /usr/src/linux pointing to your current kernel source code.
sys-kernel/gentoo-sources symlink
sys-kernel/zen-sources symlink

# Disable legacy translation databases for modern IPP printers
net-print/cups-meta -foomatic
net-print/cups-filters -foomatic
