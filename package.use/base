# ssl: Mandatory for secure web traffic, fetching packages, and encrypted
# communication.
#
# nvme: Enables tooling and support for NVM Express fast storage devices.
#
# bluetooth: Enables the Bluetooth hardware and protocol stack.
#
# lvm: Enables Logical Volume Manager support for flexible disk partition
# management.
#
# bash-completion: Adds programmable tab-completion support for the Bash shell.
#
# lm-sensors: Enables hardware health monitoring (temperatures, fan speeds,
# voltages).
#
# verify-sig: Instructs Portage to verify upstream PGP cryptographic signatures
# of downloaded source tarballs.
#
# cryptsetup: Enables dm-crypt/LUKS full-disk encryption management support.
#
# ssl: Mandatory for secure web traffic, fetching packages, and encrypted
# communication.
*/* lvm cryptsetup ssl nvme bash-completion lm-sensors verify-sig

# udev: Handles dynamic device management. Your system will not map hardware
# properly without it.
#
# dbus: Required for inter-process communication. Nearly all modern Linux
# subsystems expect it.
*/* udev dbus

# The symlink flag automatically creates or updates a symbolic link at
# /usr/src/linux pointing to your current kernel source code.
sys-kernel/gentoo-sources symlink
sys-kernel/zen-sources symlink

# Allow gcc to use polyhedral loop optimizations (such as -floop-nest-optimize)
# to speed up mathematical operations across your system packages, GCC must be
# built with the native capability to process those instructions. Enabling this
# flag pulls in dev-libs/isl to handle structural loop geometry transformations.
sys-devel/gcc graphite

# Compression
*/* zlib bzip2 lzma zstd lz4 lzo zip rar
