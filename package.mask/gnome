# This configuration block pins the GNOME desktop stack and its core
# dependencies to the stable 48 release branch by explicitly masking GNOME 49
# components and testing libraries such as glib 2.86 and newer. It prevents
# Portage from performing a partial, mixed-branch upgrade that would break the
# dependency graph, ensuring a consistent system state by resolving conflicts
# between stable amd64 packages and ~amd64 testing frameworks.
#
# It fixes:
# ---------
# !!! All ebuilds that could satisfy ">=dev-libs/glib-2.86.0:2" have been masked.
# !!! One of the following masked packages is required to complete your request:
# - dev-libs/glib-2.88.2::gentoo (masked by: package.mask)
# /etc/portage/package.mask/00my-gnome:
# # sys-apps/portage: mask testing glib and gnome-settings-daemon
# #
# # Mask >dev-libs/glib-2.86.0 and >gnome-base/gnome-settings-daemon-48.99
# # to resolve a dependency conflict between stable amd64 GNOME components
# # (gjs, gnome-control-center) and testing ~amd64 libraries. This prevents
# # Portage from pulling in mismatched testing frameworks while running with
# # --autounmask-write=n.
#
# - dev-libs/glib-2.88.1::gentoo (masked by: package.mask, ~amd64 keyword)
# - dev-libs/glib-2.86.5-r1::gentoo (masked by: package.mask, ~amd64 keyword)
#
# (dependency required by "dev-libs/gjs-1.88.0-r1::gentoo" [ebuild])
# For more information, see the MASKED PACKAGES section in the emerge
# man page or refer to the Gentoo Handbook.
>=dev-libs/glib-2.86.0
>=gnome-base/gnome-settings-daemon-48.99
>=x11-wm/mutter-49.0
>=gnome-base/gnome-shell-49.0
>=dev-libs/gjs-1.88.0
>=gnome-base/gdm-49.0
